{
  "manifest_version": "0.3",
  "name": "medical-codes-mcp-server",
  "version": "0.2.3",
  "license": "Apache-2.0",
  "description": "Decode, search, validate, and crosswalk US medical codes — ICD-10-CM, ICD-10-PCS, HCPCS Level II, RxNorm — over a bundled offline index. Keyless, deterministic.",
  "author": { "name": "cyanheads" },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyanheads/medical-codes-mcp-server"
  },
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_AUTH_MODE": "none",
        "NODE_ENV": "production"
      }
    }
  },
  "compatibility": {
    "runtimes": { "node": ">=24.0.0" }
  },
  "tools_generated": true,
  "prompts_generated": false,
  "user_config": {}
}
