# =============================================================================
# APPLICATION SPECIFIC
# =============================================================================
.storage/
repomix-output*
# The bundled SQLite index is the package's core artifact — track and ship it.
# Ignore everything else under data/ (scratch DBs, source extracts).
data/*
!data/medical-codes.db
# Federal source files the build script ingests (extracted ZIPs / order files /
# tabular XML). The build input, re-downloadable from the .gov URLs — never
# committed; only the baked data/medical-codes.db ships.
.sources/
# Generated test fixture DB (built on demand by tests/helpers/index-fixture.ts).
tests/fixtures/*.db
docs/api/
docs/devdocs.md
.mcp.json
.claude/
.agents/
.mcpregistry_github_token
.mcpregistry_registry_token

# Internal design brief (catalog frontmatter) — local only, not for public repo
docs/idea.md
